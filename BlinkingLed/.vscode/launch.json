{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "STM32F103 Debug (ST-LINK GDB Server)",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "servertype": "stlink",
      "serverpath": "C:/ST/STM32CubeCLT_1.20.0/STLink-gdb-server/bin/ST-LINK_gdbserver.exe",
      "gdbPath": "C:/ST/STM32CubeCLT_1.20.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb.exe",
      "executable": "${workspaceFolder}/build/Debug/BlinkingLed.elf",
      "device": "STM32F103C8",
      "interface": "swd",
      "runToEntryPoint": "main",
      "preLaunchTask": "CMake Build Debug"
    },
    {
      "name": "STM32F103 Debug (OpenOCD)",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "servertype": "openocd",
      "executable": "${workspaceFolder}/build/Debug/BlinkingLed.elf",
      "device": "STM32F103C8",
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f1x.cfg"
      ],
      "runToEntryPoint": "main",
      "preLaunchTask": "CMake Build Debug"
    }
  ]
}
